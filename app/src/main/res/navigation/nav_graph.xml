<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.triviaclash.app.fragments.SplashFragment"
        android:label="Splash" >
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.triviaclash.app.fragments.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.triviaclash.app.fragments.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.triviaclash.app.fragments.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_categories"
            app:destination="@id/categoryFragment" />
        <action
            android:id="@+id/action_home_to_leaderboard"
            app:destination="@id/leaderboardFragment" />
        <action
            android:id="@+id/action_home_to_profile"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.triviaclash.app.fragments.CategoryFragment"
        android:label="Categories">
        <action
            android:id="@+id/action_category_to_quiz"
            app:destination="@id/quizFragment" />
    </fragment>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.triviaclash.app.fragments.QuizFragment"
        android:label="Quiz">
        <argument
            android:name="category"
            app:argType="string"
            android:defaultValue="science" />
        <action
            android:id="@+id/action_quiz_to_results"
            app:destination="@id/resultsFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultsFragment"
        android:name="com.triviaclash.app.fragments.ResultsFragment"
        android:label="Results">
        <argument
            android:name="score"
            app:argType="integer"
            android:defaultValue="0" />
        <argument
            android:name="correctAnswers"
            app:argType="integer"
            android:defaultValue="0" />
        <argument
            android:name="totalQuestions"
            app:argType="integer"
            android:defaultValue="0" />
        <action
            android:id="@+id/action_results_to_home"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_results_to_categories"
            app:destination="@id/categoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/leaderboardFragment"
        android:name="com.triviaclash.app.fragments.LeaderboardFragment"
        android:label="Leaderboard" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.triviaclash.app.fragments.ProfileFragment"
        android:label="Profile" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.triviaclash.app.fragments.SettingsFragment"
        android:label="Settings" />

    <fragment
        android:id="@+id/achievementsFragment"
        android:name="com.triviaclash.app.fragments.AchievementsFragment"
        android:label="Achievements" />

</navigation>